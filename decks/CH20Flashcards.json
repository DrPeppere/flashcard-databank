[
    { q: "Trace a piece of undigested food from the mouth to the anus.", a: "Oral cavity -> Esophagus -> Stomach -> Small intestine (Duodenum -> Jejunum -> Ileum) -> Large intestine (Colon -> Rectum) -> Anus", sec: "21.1 Anatomy" },
    { q: "Define gastrointestinal tract (GI tract)", a: "Location: A long tube consisting of the esophagus, stomach, small intestine, and large intestine. Function: A receptacle and pathway for food to undergo digestion, absorption, secretion, and motility.", sec: "21.1 Anatomy" },
    { q: "Define gut", a: "Location: The portion of the GI tract running specifically from the stomach to the anus. Function: Where the majority of digestion, absorption, and waste concentration takes place.", sec: "21.1 Anatomy" },
    { q: "Define chyme", a: "Location: Exists in the lumen of the GI tract (stomach and intestines). Function: A soupy mixture of food and secretions created by the chemical and mechanical breakdown of ingested food.", sec: "21.1 Anatomy" },
    { q: "Define oral cavity", a: "Location: The receptacle for food consisting of the mouth and pharynx. Function: Where the first stages of mechanical digestion (chewing) and chemical digestion (saliva) begin.", sec: "21.1 Anatomy" },
    { q: "Define salivary glands", a: "Location: Three pairs of accessory organs (sublingual, submandibular, parotid) around the oral cavity. Function: Secrete saliva to soften food, digest starch, dissolve molecules for taste, and provide defense.", sec: "21.1 Anatomy" },
    { q: "Define esophagus", a: "Location: A narrow tube traveling through the thorax to the abdomen. Function: Transports swallowed food (bolus) from the pharynx to the stomach via peristalsis.", sec: "21.1 Anatomy" },
    { q: "Define stomach", a: "Location: A baglike organ just below the diaphragm, between the esophagus and small intestine. Function: Stores food, chemically and mechanically digests food into chyme, and defends against pathogens.", sec: "21.1 Anatomy" },
    { q: "Define pancreas", a: "Location: An accessory glandular organ situated near the stomach and duodenum. Function: Exocrine secretion of enzymes and bicarbonate into the intestine; endocrine secretion of insulin and glucagon into the blood.", sec: "21.1 Anatomy" },
    { q: "Define liver", a: "Location: The largest internal organ, positioned below the diaphragm. Function: Secretes bile to facilitate fat digestion, filters absorbed nutrients from the hepatic portal system, and clears xenobiotics.", sec: "21.1 Anatomy" },
    { q: "Define small intestine", a: "Location: The section of the GI tract between the stomach and large intestine. Function: The primary site where chemical digestion finishes and nearly all digested nutrients, fluids, and secreted ions are absorbed.", sec: "21.1 Anatomy" },
    { q: "Define duodenum", a: "Location: The first 25 cm of the small intestine. Function: Receives chyme from the stomach and mixes it with pancreatic secretions and bile for digestion.", sec: "21.1 Anatomy" },
    { q: "Define jejunum", a: "Location: The middle section of the small intestine. Function: Continues the digestion of chyme and acts as a major site for the absorption of nutrients.", sec: "21.1 Anatomy" },
    { q: "Define ileum", a: "Location: The terminal section of the small intestine. Function: Completes absorption, specifically of Vitamin B12 and bile salts, before emptying unabsorbed chyme into the large intestine.", sec: "21.1 Anatomy" },
    { q: "Define large intestine", a: "Location: The terminal section of the GI tract containing the colon and rectum. Function: Concentrates waste into semisolid feces by absorbing remaining water and electrolytes.", sec: "21.1 Anatomy" },
    { q: "Define colon", a: "Location: The proximal section of the large intestine. Function: Absorbs water and electrolytes out of watery chyme to create semisolid feces, and houses commensal bacteria.", sec: "21.1 Anatomy" },
    { q: "Define feces", a: "Location: Stored in the terminal section of the large intestine. Function: The concentrated, semisolid waste remaining after digestion and absorption, waiting to be expelled.", sec: "21.1 Anatomy" },
    { q: "Define rectum", a: "Location: The short (about 12 cm) terminal section of the large intestine. Function: Stores feces; distension of the rectal wall triggers the defecation reflex.", sec: "21.1 Anatomy" },
    { q: "Define anus", a: "Location: The opening at the end of the GI tract. Function: Serves as the exit point for feces, controlled by an internal smooth muscle sphincter and an external skeletal muscle sphincter.", sec: "21.1 Anatomy" },
    { q: "Describe the four layers of the GI tract wall.", a: "1) Mucosa (inner lining facing the lumen), 2) Submucosa (connective tissue layer with blood/lymph vessels), 3) Muscularis externa (outer wall of smooth muscle), 4) Serosa (outer covering of connective tissue).", sec: "21.1 Anatomy" },
    { q: "Define villi", a: "Location: Small fingerlike extensions projecting from the mucosal surface into the lumen of the small intestine. Function: Increase the effective surface area of the intestine to enhance nutrient absorption.", sec: "21.1 Anatomy" },
    { q: "Define gastric glands", a: "Location: Tubular invaginations extending deep into the supporting connective tissue of the stomach mucosa. Function: Contain cells that secrete gastric acid, enzymes, hormones, and paracrine molecules.", sec: "21.1 Anatomy" },
    { q: "Define crypts", a: "Location: Tubular invaginations of the mucosal surface in the intestine. Function: Contain rapidly dividing stem cells for renewal, and house cells that secrete fluid, ions, and hormones.", sec: "21.1 Anatomy" },
    { q: "Define submucosal glands", a: "Location: Some of the deepest invaginations forming within the gut wall. Function: Secretory glands that open into the lumen of the digestive tract through ducts.", sec: "21.1 Anatomy" },
    { q: "Define mucosa", a: "Location: The inner lining of the gastrointestinal tract facing the lumen. Function: Facilitates absorption and secretion, consisting of a mucosal epithelium, lamina propria, and muscularis mucosae.", sec: "21.1 Anatomy" },
    { q: "Define submucosa", a: "Location: The middle layer of the gut wall between the mucosa and muscularis externa. Function: Carries larger blood and lymph vessels and contains the submucosal nerve plexus (Meissner's plexus).", sec: "21.1 Anatomy" },
    { q: "Define muscularis externa", a: "Location: The outer wall of the GI tract consisting of inner circular and outer longitudinal smooth muscle layers. Function: Contractions decrease lumen diameter and shorten the tube for motility.", sec: "21.1 Anatomy" },
    { q: "Define serosa", a: "Location: The outer covering of the entire digestive tract. Function: A connective tissue membrane forming a continuation of the peritoneal membrane to hold intestines in place.", sec: "21.1 Anatomy" },
    { q: "Define mucosal epithelium (mucosal vs serosal)", a: "The mucosal (apical) surface faces the lumen and secretes ions, enzymes, and mucus. The serosal (basolateral) surface faces the extracellular fluid where absorbed substances are transferred into the blood/lymph.", sec: "21.1 Anatomy" },
    { q: "Define lamina propria", a: "Location: Subepithelial connective tissue just below the mucosal epithelium. Function: Holds epithelium in place and contains nerve fibers, small blood/lymph vessels, and immune cells (macrophages/lymphocytes).", sec: "21.1 Anatomy" },
    { q: "Define muscularis mucosae", a: "Location: A thin layer of smooth muscle separating the lamina propria from the submucosa. Function: Contraction alters the effective surface area for absorption by moving the villi back and forth.", sec: "21.1 Anatomy" },
    { q: "Describe the primary function of the digestive system.", a: "To move nutrients, water, and electrolytes from the external environment into the body's internal environment for use.", sec: "21.2 Digestion/Processes" },
    { q: "Describe secretion in the GI tract.", a: "The movement of water and ions from the ECF to the digestive tract lumen, OR the release of substances synthesized by GI epithelial cells into the lumen or ECF.", sec: "21.2 Digestion/Processes" },
    { q: "Describe digestion in the GI tract.", a: "The chemical and mechanical breakdown of foods into smaller units that can be taken across the intestinal epithelium into the body.", sec: "21.2 Digestion/Processes" },
    { q: "Describe absorption in the GI tract.", a: "The movement of substances from the lumen of the GI tract to the extracellular fluid for distribution throughout the body.", sec: "21.2 Digestion/Processes" },
    { q: "Describe motility in the GI tract.", a: "The movement of material in the GI tract as a result of muscle contraction.", sec: "21.2 Digestion/Processes" },
    { q: "Locate where secretion occurs in the GI tract.", a: "Salivary glands (saliva), Stomach (HCl, pepsinogen, mucus), Small intestine (brush border enzymes, mucus), Liver (bile), Pancreas (enzymes, bicarbonate), Large intestine (mucus).", sec: "21.2 Digestion/Processes" },
    { q: "Locate where digestion occurs in the GI tract.", a: "Mouth (carbohydrates via amylase), Stomach (proteins via pepsin, some fats), Small intestine (polypeptides, carbohydrates, fats, nucleic acids).", sec: "21.2 Digestion/Processes" },
    { q: "Locate where absorption occurs in the GI tract.", a: "Stomach (lipid-soluble substances like alcohol/aspirin), Small Intestine (primary site for amino acids, sugars, fats, water, ions, vitamins), Large Intestine (remaining ions, water, small organic molecules).", sec: "21.2 Digestion/Processes" },
    { q: "Locate where motility occurs in the GI tract.", a: "Mouth (chewing, swallowing), Esophagus (peristalsis), Stomach (peristaltic mixing/propulsion), Small intestine (segmentation, some peristalsis), Large intestine (segmental mixing, mass movement).", sec: "21.2 Digestion/Processes" },
    { q: "Discuss the role of mass balance within the digestive system.", a: "To maintain homeostasis, the volume of fluid entering the GI tract by intake (2 L) or internal secretion (7 L) must equal the volume leaving the lumen via absorption (nearly 9 L), preventing dehydration.", sec: "21.2 Digestion/Processes" },
    { q: "Explain the challenge of autodigestion.", a: "The system must secrete powerful enzymes to digest macromolecules into small absorbable molecules, but these enzymes must not digest the cells of the GI tract itself.", sec: "21.2 Digestion/Processes" },
    { q: "Explain the challenge of mass balance.", a: "The system receives 2 liters of fluid intake plus 7 liters of secreted fluid daily; if the intestine cannot efficiently reabsorb this 9 liters, the body will rapidly dehydrate.", sec: "21.2 Digestion/Processes" },
    { q: "Explain the challenge of defense.", a: "The GI tract has a massive surface area directly exposed to the external environment, requiring mucus, enzymes, acid, and gut-associated lymphoid tissue (GALT) to prevent pathogens from entering the body.", sec: "21.2 Digestion/Processes" },
    { q: "Discuss the roles of digestive enzymes.", a: "Synthesized and secreted by exocrine glands or epithelial cells to chemically break down food. Many are secreted as inactive proenzymes (zymogens) to prevent autodigestion inside the secretory cells.", sec: "21.2 Digestion/Processes" },
    { q: "Discuss the roles of mucus in digestion.", a: "A viscous secretion of mucins made by mucous cells/goblet cells that forms a protective coating over the GI mucosa to prevent autodigestion and lubricates the contents of the gut.", sec: "21.2 Digestion/Processes" },
    { q: "Describe and compare peristalsis and segmentation.", a: "Peristalsis is a progressive wave of contraction that pushes a food bolus forward. Segmentation involves alternating contraction and relaxation of short segments to mix and churn chyme without net forward movement.", sec: "21.2 Digestion/Processes" },
    { q: "Describe the migrating motor complex.", a: "A housekeeping pattern of motility between meals consisting of a series of contractions passing slowly from the stomach to the large intestine to sweep food remnants and bacteria out of the upper GI tract.", sec: "21.2 Digestion/Processes" },
    { q: "Describe the intestinal phase of digestion.", a: "Begins when chyme enters the small intestine, triggering neural and endocrine reflexes that slow gastric emptying, promote secretion of bicarbonate/enzymes/bile, and facilitate nutrient digestion and absorption.", sec: "21.6 Intestinal Phase" },
    { q: "Explain how the anatomy of the small intestine facilitates secretion, digestion, and absorption.", a: "Surface area is drastically increased by macroscopic folds (plicae), fingerlike villi, and deep crypts, as well as microscopic microvilli (brush border) on the apical surface of enterocytes.", sec: "21.6 Intestinal Phase" },
    { q: "Understand the role of the pancreas in endocrine function.", a: "Endocrine secretions come from clusters of cells called islets, which secrete hormones like insulin and glucagon directly into the bloodstream to regulate metabolism.", sec: "21.6 Intestinal Phase" },
    { q: "Understand the role of the pancreas in exocrine function.", a: "Acinar cells secrete digestive enzymes (as zymogens), and duct cells secrete a watery sodium bicarbonate solution into the duodenum through the pancreatic duct to aid digestion.", sec: "21.6 Intestinal Phase" },
    { q: "Describe the role and location of digestive enzymes.", a: "Produced by the exocrine pancreas (acini) and intestinal epithelium (brush border). They chemically break down polypeptides, carbohydrates, fats, and nucleic acids in the small intestine.", sec: "21.6 Intestinal Phase" },
    { q: "Describe the role and location of bile and bile salts.", a: "Synthesized by hepatocytes in the liver and stored in the gallbladder. Secreted into the duodenum to act as detergents that emulsify large fat droplets into smaller particles for digestion.", sec: "21.6 Intestinal Phase" },
    { q: "Describe the role and location of bicarbonate.", a: "Produced primarily by pancreatic duct cells (and some duodenal cells). Secreted into the small intestine to neutralize the highly acidic chyme entering from the stomach.", sec: "21.6 Intestinal Phase" },
    { q: "Describe the role and location of mucus in the intestinal phase.", a: "Secreted by goblet cells located in the intestinal epithelium and crypts. It protects the mucosal epithelium from damage and lubricates the contents of the gut.", sec: "21.6 Intestinal Phase" },
    { q: "Describe the role and location of isotonic NaCl solution (CFTR channels).", a: "Secreted by crypt cells in the small intestine and colon. Cl- enters the lumen via apical CFTR channels, drawing Na+ and water paracellularly to create a lubricating saline solution.", sec: "21.6 Intestinal Phase" },
    { q: "Explain where the digestion and absorption of fats takes place.", a: "Less than one-third of digestion occurs in the stomach; the vast majority of fat digestion and all of fat absorption takes place in the small intestine.", sec: "21.6 Intestinal Phase" },
    { q: "Define amphipathic in fat digestion", a: "Molecules like bile salts have both a hydrophobic region (which associates with lipid droplets) and a hydrophilic region (which interacts with water), allowing them to create a stable emulsion of fats.", sec: "21.6 Intestinal Phase" },
    { q: "Define lipases", a: "Pancreatic enzymes responsible for enzymatic fat digestion; they remove two fatty acids from each triglyceride molecule, resulting in one monoglyceride and two free fatty acids.", sec: "21.6 Intestinal Phase" },
    { q: "Define colipase", a: "A protein cofactor secreted by the pancreas that displaces some bile salts from the surface of the fat emulsion, allowing lipase to gain access to the fats inside.", sec: "21.6 Intestinal Phase" },
    { q: "Define micelles", a: "Small disk-shaped structures containing bile salts, phospholipids, fatty acids, cholesterol, and mono-/diglycerides that ferry lipid components to the brush border for absorption.", sec: "21.6 Intestinal Phase" },
    { q: "Define phospholipase", a: "A digestive enzyme secreted by the pancreas responsible for breaking down phospholipids into their absorbable components in the small intestine.", sec: "21.6 Intestinal Phase" },
    { q: "Define chylomicrons", a: "Large droplets formed inside the smooth ER of enterocytes containing recombined triglycerides, cholesterol, and proteins, which are packaged into vesicles for exocytosis.", sec: "21.6 Intestinal Phase" },
    { q: "Define lacteals", a: "Lymph vessels located within the intestinal villi that absorb large chylomicrons from the extracellular space, because chylomicrons are too large to cross the capillary basement membrane.", sec: "21.6 Intestinal Phase" },
    { q: "Explain where the digestion and absorption of carbohydrates takes place.", a: "Digestion starts in the mouth (salivary amylase), pauses in the stomach, and completes in the small intestine (pancreatic amylase, brush border enzymes) where absorption also occurs.", sec: "21.6 Intestinal Phase" },
    { q: "Define polysaccharides", a: "Complex carbohydrates consisting of long glucose polymers. Digestible forms include starch and glycogen, while cellulose is an indigestible form.", sec: "21.6 Intestinal Phase" },
    { q: "Define disaccharides", a: "Carbohydrates composed of two sugar molecules, such as lactose (milk sugar), maltose, and sucrose (table sugar), which must be broken down by brush border enzymes.", sec: "21.6 Intestinal Phase" },
    { q: "Define monosaccharides", a: "Simple, absorbable sugars including glucose, galactose, and fructose, which are the final end products of carbohydrate digestion.", sec: "21.6 Intestinal Phase" },
    { q: "Define amylase", a: "An enzyme secreted by salivary glands and the pancreas that breaks down long glucose polymers (starch/glycogen) into smaller glucose chains and the disaccharide maltose.", sec: "21.6 Intestinal Phase" },
    { q: "Define fiber", a: "Indigestible complex carbohydrates, such as cellulose from plant matter, that pass through the human GI tract without being absorbed, also known as roughage.", sec: "21.6 Intestinal Phase" },
    { q: "Define lactase", a: "An intestinal brush border disaccharidase enzyme that breaks down lactose (milk sugar) into absorbable glucose and galactose monosaccharides.", sec: "21.6 Intestinal Phase" },
    { q: "Define SGLT transporter", a: "An apical sodium-dependent symporter on enterocytes that actively transports both glucose and galactose from the intestinal lumen into the cell.", sec: "21.6 Intestinal Phase" },
    { q: "Define GLUT2", a: "A basolateral transport protein on enterocytes that moves absorbed glucose, galactose, and fructose out of the cell and into the extracellular fluid by facilitated diffusion.", sec: "21.6 Intestinal Phase" },
    { q: "Define GLUT5", a: "An apical transport protein on enterocytes that moves fructose into the cell via sodium-independent facilitated diffusion.", sec: "21.6 Intestinal Phase" },
    { q: "Explain where the digestion and absorption of proteins takes place.", a: "Initial protein digestion takes place in the stomach (pepsin), and it is completed in the small intestine by pancreatic and brush border enzymes, followed by absorption into enterocytes.", sec: "21.6 Intestinal Phase" },
    { q: "Define endopeptidases", a: "Enzymes that attack peptide bonds in the interior of an amino acid chain, breaking a long peptide chain into smaller fragments.", sec: "21.6 Intestinal Phase" },
    { q: "Define proteases", a: "The common name for endopeptidases (like pepsin, trypsin, and chymotrypsin); they are secreted as inactive zymogens from the stomach, intestine, and pancreas.", sec: "21.6 Intestinal Phase" },
    { q: "Define pepsin", a: "An endopeptidase secreted as inactive pepsinogen by chief cells in the stomach; it is activated by low gastric pH to carry out initial digestion of proteins.", sec: "21.6 Intestinal Phase" },
    { q: "Define trypsin", a: "A pancreatic endopeptidase secreted as trypsinogen and activated by brush border enteropeptidase. Trypsin subsequently activates all other pancreatic zymogens in a cascade.", sec: "21.6 Intestinal Phase" },
    { q: "Define exopeptidase", a: "Enzymes that release single amino acids from peptides by chopping them off the ends, one at a time (e.g., aminopeptidase at the amino-terminal, carboxypeptidase at the carboxy-terminal).", sec: "21.6 Intestinal Phase" },
    { q: "Explain the cellular mechanism for absorption of water.", a: "Water absorption is passive and unregulated, following the osmotic gradients created by the absorption of solutes (like Na+ and Cl-) from the lumen to the ECF via paracellular pathways or channels.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the cellular mechanism for absorption of fat-soluble vitamins (A, D, E, K).", a: "They are packaged into micelles in the small intestine and absorbed alongside lipophilic fats primarily through simple diffusion into the enterocyte.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the cellular mechanism for absorption of water-soluble vitamins (C, most B).", a: "They are absorbed across the intestinal epithelium primarily through specific mediated transport proteins.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the cellular mechanism for absorption of Vitamin B12.", a: "Requires complexing with intrinsic factor in the stomach; the complex is then recognized and absorbed exclusively by a specific intestinal transporter found only in the ileum.", sec: "21.6 Intestinal Phase" },
    { q: "Define intrinsic factor", a: "A protein secreted by parietal cells in the gastric glands that binds to Vitamin B12, acting as a crucial complex necessary for the vitamin's absorption in the terminal ileum.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the cellular mechanism for absorption of iron.", a: "Heme iron enters via an apical transporter. Ionized iron (Fe2+) enters via apical cotransport with H+ on DMT1. Both pools exit basolaterally via the ferroportin transporter.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the cellular mechanism for absorption of calcium.", a: "Occurs passively via unregulated paracellular pathways, or actively in the duodenum via apical Ca2+ channels and basolateral Ca2+-ATPase/Na+-Ca2+ antiporters, regulated by Vitamin D3.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the neural control of the intestinal phase of digestion.", a: "Chyme entering the intestine activates enteric nervous system sensors, triggering short reflexes that decrease gastric motility and secretion to slow the delivery of chyme.", sec: "21.6 Intestinal Phase" },
    { q: "Define enteric nervous system", a: "A complex network of intrinsic neurons within the gut wall that acts as its own integrating center to control motility, secretion, and growth of the digestive tract independent of the CNS.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the hormonal control involving secretin.", a: "Stimulus: Acidic chyme in the duodenum. Effects: Inhibits gastric acid production/motility and stimulates the pancreas to secrete bicarbonate to neutralize the acid.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the hormonal control involving cholecystokinin (CCK).", a: "Stimulus: Fatty acids and amino acids in the meal. Effects: Slows gastric motility/acid secretion, stimulates gallbladder contraction, and promotes pancreatic enzyme secretion.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the hormonal control involving gastric inhibitor peptide (GIP).", a: "Stimulus: Carbohydrates or fats in the intestinal lumen. Effects: Acts as an incretin hormone to stimulate feedforward insulin release, and inhibits gastric emptying.", sec: "21.6 Intestinal Phase" },
    { q: "Explain the hormonal control involving glucagon-like peptide-1 (GLP-1).", a: "Stimulus: Mixed meal with carbs/fats. Effects: Works with GIP to stimulate insulin release, while also inhibiting glucagon release and slowing gastric function/motility.", sec: "21.6 Intestinal Phase" },
    { q: "END", a: "END", sec: "END" }
]
